            "body": { "mode": "raw", "raw": "{\n  \"mascota_id\": 1,\n  \"fecha\": \"2026-07-10T10:00:00.000Z\",\n  \"motivo\": \"Revisión general\",\n  \"profesional\": \"Ana Gómez\",\n  \"estado\": \"Programada\"\n}" }
