{
  "info": {
    "name": "PetCare API v1",
    "_postman_id": "petcare-api-v1",
    "description": "Colección completa de la API PetCare. Ejecutar 'Login' primero y copiar el access_token en la variable {{token}} del entorno.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "token",    "value": "<pegar access_token después de Login>" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/"
      }
    },
    {
      "name": "Usuarios",
      "item": [
        {
          "name": "Registro",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/usuarios/registro",
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Carlos Test\",\n  \"email\": \"carlos@test.com\",\n  \"password\": \"1234\"\n}" }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/usuarios/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"adrian@ejemplo.com\",\n  \"password\": \"1234\"\n}" }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/usuarios/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"<pegar refresh_token>\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/usuarios/logout",
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"<pegar refresh_token>\"\n}" }
          }
        },
        {
          "name": "Obtener por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/v1/usuarios/1"
          }
        },
        {
          "name": "Actualizar",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/v1/usuarios/1",
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Adrian Ruiz Actualizado\",\n  \"email\": \"adrian@ejemplo.com\",\n  \"foto_url\": null\n}" }
          }
        },
        {
          "name": "Eliminar",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/v1/usuarios/1"
          }
        }
      ]
    },
    {
      "name": "Mascotas",
      "item": [
        {
          "name": "Listar todas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/v1/mascotas"
