          }
        },
        {
          "name": "Cambiar estado — Confirmar",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/v1/citas/1/estado",
            "body": { "mode": "raw", "raw": "{\n  \"estado\": \"Confirmada\"\n}" }
          }
        },
        {
          "name": "Cambiar estado — Cancelar",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/v1/citas/1/estado",
            "body": { "mode": "raw", "raw": "{\n  \"estado\": \"Cancelada\"\n}" }
          }
        },
        {
          "name": "Cambiar estado — Completar",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/v1/citas/1/estado",
            "body": { "mode": "raw", "raw": "{\n  \"estado\": \"Completada\"\n}" }
          }
        },
        {
          "name": "Eliminar",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/v1/citas/1"
          }
        }
      ]
    },
