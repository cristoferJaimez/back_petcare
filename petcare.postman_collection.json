            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/v1/mascotas",
            "body": { "mode": "raw", "raw": "{\n  \"usuario_id\": 1,\n  \"raza_id\": 1,\n  \"nombre\": \"Rocky\",\n  \"especie\": \"Perro\",\n  \"edad\": 2,\n  \"peso\": 15.5,\n  \"sexo\": \"macho\",\n  \"dieta\": \"Concentrado\",\n  \"vacunacion_al_dia\": true,\n  \"notas\": \"Le gusta correr en el parque\"\n}" }
          }
        },
        {
          "name": "Actualizar",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/v1/mascotas/1",
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Pegotes Actualizado\",\n  \"edad\": 4,\n  \"notas\": \"Nota actualizada\"\n}" }
          }
        },
        {
          "name": "Eliminar",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/v1/mascotas/1"
          }
        }
      ]
    },
    {
